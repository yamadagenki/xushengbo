---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = '徐 聖博 — 株式会社シンシア 代表取締役',
  description = '徐 聖博(Xu Shengbo)の個人サイト。株式会社シンシア 代表取締役。東京大学で機械学習・進化計算を研究し、グリー・メドレー・Indeed・リクルートを経て2020年にシンシアを創業。',
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${base}/images/favicon.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>Xu Shengbo | {title}</title>
    <meta property="og:title" content={`Xu Shengbo | ${title}`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://yamadagenki.github.io/xushengbo/images/ogimage.png" />
    <meta property="og:url" content="https://yamadagenki.github.io/xushengbo/" />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --ink:         #0f172a;
    --ink-soft:    #334155;
    --muted:       #64748b;
    --line:        #e6e8ee;
    --bg:          #ffffff;
    --bg-soft:     #f7f8fb;
    --accent:      #4f46e5;
    --accent-2:    #7c3aed;
    --accent-ink:  #4338ca;
    --radius:      16px;
    --radius-sm:   10px;
    --shadow:      0 1px 2px rgba(15,23,42,.04), 0 8px 24px rgba(15,23,42,.06);
    --shadow-hov:  0 2px 4px rgba(15,23,42,.06), 0 16px 40px rgba(15,23,42,.14);
    --maxw:        960px;
    --font:        'Inter', 'Noto Sans JP', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; }

  body {
    background: var(--bg);
    color: var(--ink);
    font-family: var(--font);
    font-weight: 400;
    line-height: 1.7;
    letter-spacing: .01em;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; height: auto; display: block; }
</style>

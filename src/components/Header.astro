---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---
<header class="header">
  <div class="inner">
    <a href={base} class="logo">Xu Shengbo</a>
    <nav class="nav">
      <a href="#message">Message</a>
      <a href="#career">Career</a>
      <a href="#publications">Publications</a>
      <a href="#articles">Articles</a>
    </nav>
    <div class="social">
      <a href="https://www.facebook.com/xu.shengbo" target="_blank" rel="noopener" aria-label="Facebook">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.268h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/></svg>
      </a>
      <a href="https://twitter.com/yamadagenki0607" target="_blank" rel="noopener" aria-label="X (Twitter)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255,255,255,.85);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid var(--line);
  }
  .inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 24px;
    height: 64px;
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .logo {
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -.03em;
    color: var(--ink);
    flex-shrink: 0;
  }
  .nav {
    display: flex;
    gap: 28px;
    margin-left: 8px;
  }
  .nav a {
    font-size: 14px;
    font-weight: 600;
    color: var(--muted);
    transition: color .15s;
  }
  .nav a:hover { color: var(--ink); }
  .social {
    margin-left: auto;
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .social a {
    color: var(--muted);
    transition: color .15s;
    display: flex;
    align-items: center;
  }
  .social a:hover { color: var(--ink); }

  @media (max-width: 640px) {
    .nav { display: none; }
  }
</style>

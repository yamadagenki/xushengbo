---
<section class="articles" id="articles">
  <div class="inner">
    <span class="label">Articles</span>
    <ul class="list">
      {articles.map(a => (
        <li class="item">
          <time class="date">{a.date}</time>
          <a href={a.url} target="_blank" rel="noopener" class="link">{a.title}</a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .articles {
    padding: 72px 0;
    border-bottom: 1px solid var(--line);
  }
  .inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 24px;
  }
  .label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent-ink);
    margin-bottom: 28px;
  }
  .list { list-style: none; }
  .item {
    display: flex;
    align-items: baseline;
    gap: 18px;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
    transition: padding-left .18s;
  }
  .item:first-child { border-top: 1px solid var(--line); }
  .item:hover { padding-left: 6px; }
  .date {
    flex-shrink: 0;
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }
  .link {
    font-size: 15px;
    font-weight: 500;
    color: var(--ink-soft);
    line-height: 1.5;
    transition: color .15s;
  }
  .link:hover { color: var(--accent); }
</style>
